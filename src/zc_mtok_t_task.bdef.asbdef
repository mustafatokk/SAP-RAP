projection;
strict ( 2 );
use draft;

define behavior for ZC_MTOK_T_TASK //alias <alias_name>
{
  use create;
  use update;
  use delete;

  use action Activate;
  use action Edit;
  use action Resume;
  use action Discard;
  use action Prepare;

  use association _subtask { create; with draft;}
}

define behavior for ZC_MTOK_T_SUBTASK //alias <alias_name>
{
  use update;
  use delete;

  use association _parent { with draft; }
}